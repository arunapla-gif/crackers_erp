generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "crackers"]
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  mobile    String?
  reference String?
  address   String?
  city      String?
  district  String?
  state     String?
  pincode   String?
  id_number String?
  gstin     String?
  status    String   @default("Active")
  addresses Json?    @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  repId     Int?
  rep       User?    @relation("RepCustomers", fields: [repId], references: [id])
  salesOrders SalesOrder[] @relation("OrderCustomer")
  customerPrices CustomerPrice[]
  @@schema("crackers")

}

model Product {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  type      String   @default("INV") // "INV", "EP", or "RM"
  category  String?
  hsn       String   @default("3604")
  tax       Decimal  @default(18.00) @db.Decimal(5, 2)
  rate      Decimal  @default(0.00) @db.Decimal(10, 2)
  unit_qty  Int      @default(1)
  unit      String   @default("Case")
  pack_unit String?
  status    String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  factoryAliasId Int?
  factoryAlias   Product? @relation("FactoryMapping", fields: [factoryAliasId], references: [id])
  aliases        Product[] @relation("FactoryMapping")
  customerPrices CustomerPrice[]
  @@schema("crackers")

}

model CustomerPrice {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rate       Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, productId])
  @@schema("crackers")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  mobile    String?
  type      String?  @default("Raw Material")
  address   String?
  city      String?
  district  String?
  state     String?
  pincode   String?
  id_number String?
  gstin     String?
  status    String   @default("Active")
  addresses Json?    @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("crackers")

}

model Transporter {
  id        Int      @id @default(autoincrement())
  gstin     String   @unique
  name      String
  address   String?
  city      String?
  district  String?
  state     String?
  pincode   String?
  status    String   @default("Active")
  @@schema("crackers")

}


model Vehicle {
  id          Int      @id @default(autoincrement())
  no          String   @unique
  name        String?
  owner_name  String?
  owner_phone String?
  drivers     Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  transfers   StockTransfer[]
  @@schema("crackers")

}

model Invoice {
  id          Int      @id @default(autoincrement())
  series      String?
  number          String   @unique
  date            DateTime?
  customer        String?
  customerAddress String?
  state           String?
  vehicleNo       String?
  distance        Int?
  transporterId   String?
  ewayBillNo      String?
  dispatchAddress String?
  subtotal        Decimal? @db.Decimal(12, 2)
  cgst        Decimal? @db.Decimal(12, 2)
  sgst        Decimal? @db.Decimal(12, 2)
  igst        Decimal? @db.Decimal(12, 2)
  tax         Decimal? @db.Decimal(12, 2)
  grand_total Decimal? @db.Decimal(12, 2)
  items       InvoiceItem[]
  charges     InvoiceCharge[]
  companyProfileId Int?
  companyProfile   CompanyProfile? @relation(fields: [companyProfileId], references: [id])
  repId       Int?
  rep         User?    @relation("RepInvoices", fields: [repId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@schema("crackers")

}

model InvoiceItem {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  productId Int?     // Optional, as sometimes items might be entered without a strict product code
  product   String   // The name or description saved on the invoice
  hsn       String?
  qty       Int      @default(1)
  rate      Decimal  @default(0.00) @db.Decimal(10, 2)
  tax       Decimal  @default(18.00) @db.Decimal(5, 2)
  total     Decimal  @default(0.00) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("crackers")

}

model InvoiceCharge {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  name      String
  source    String   @default("MANUAL")
  mode      String   @default("ADD")
  type      String   @default("AMOUNT")
  value     Decimal  @default(0.00) @db.Decimal(12, 2)
  amount    Decimal  @default(0.00) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("crackers")

}

model Godown {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  purchases     PurchaseItem[]
  stock         StockLedger[]
  transfersFrom StockTransferItem[] @relation("TransferFromGodown")
  transfersTo   StockTransferItem[] @relation("TransferToGodown")
  @@schema("crackers")

}

model Purchase {
  id        Int      @id @default(autoincrement())
  number    String   @unique
  date      DateTime
  supplier  String
  billNo    String
  qty       Int      @default(0)
  subtotal  Decimal  @default(0.00) @db.Decimal(12, 2)
  tax       Decimal  @default(0.00) @db.Decimal(12, 2)
  cgst      Decimal  @default(0.00) @db.Decimal(12, 2)
  sgst      Decimal  @default(0.00) @db.Decimal(12, 2)
  igst      Decimal  @default(0.00) @db.Decimal(12, 2)
  discount  Decimal  @default(0.00) @db.Decimal(12, 2)
  value     Decimal  @default(0.00) @db.Decimal(12, 2)
  status    String   @default("Active")
  items     PurchaseItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("crackers")

}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  godownId   Int
  godown     Godown   @relation(fields: [godownId], references: [id])
  productId  Int?
  product    String
  packs      Int      @default(0)
  pack_unit  String?
  pricing_unit String?
  qty        Int
  rate       Decimal  @db.Decimal(10, 2)
  amount     Decimal  @db.Decimal(12, 2)
  discount   Decimal  @default(0.00) @db.Decimal(12, 2)
  tax_rate   Decimal  @default(18.00) @db.Decimal(5, 2)
  tax_amt    Decimal  @default(0.00) @db.Decimal(12, 2)
  net_amount Decimal  @default(0.00) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@schema("crackers")

}

model StockLedger {
  id        Int      @id @default(autoincrement())
  godownId  Int
  godown    Godown   @relation(fields: [godownId], references: [id])
  productId Int?
  product   String
  qty       Int      @default(0)
  value     Decimal  @default(0.00) @db.Decimal(12, 2)
  avgRate   Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([godownId, product])
  @@schema("crackers")

}

model StockTransfer {
  id         Int      @id @default(autoincrement())
  number     String   @unique
  date       DateTime
  vehicleId  Int?
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id])
  driverName String?
  remarks    String?
  qty        Int      @default(0)
  items      StockTransferItem[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@schema("crackers")

}

model StockTransferItem {
  id            Int      @id @default(autoincrement())
  transferId    Int
  transfer      StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  fromGodownId  Int
  fromGodown    Godown   @relation("TransferFromGodown", fields: [fromGodownId], references: [id])
  toGodownId    Int
  toGodown      Godown   @relation("TransferToGodown", fields: [toGodownId], references: [id])
  productId     Int?
  product       String
  qty           Int
  rate          Decimal  @db.Decimal(10, 2)
  value         Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("crackers")

}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  pin         String
  role        String   @default("STAFF") // "ADMIN" or "STAFF"
  permissions Json?    @default("{}")
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customers   Customer[] @relation("RepCustomers")
  invoices    Invoice[]  @relation("RepInvoices")
  salesOrders SalesOrder[] @relation("RepOrders")
  @@schema("crackers")
}

model SalesOrder {
  id              Int      @id @default(autoincrement())
  repId           Int
  rep             User     @relation("RepOrders", fields: [repId], references: [id])
  customerId      Int?
  customer        Customer? @relation("OrderCustomer", fields: [customerId], references: [id])
  newCustomerData Json?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  subtotal        Decimal  @default(0.00) @db.Decimal(12, 2)
  items           SalesOrderItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@schema("crackers")
}

model SalesOrderItem {
  id           Int        @id @default(autoincrement())
  salesOrderId Int
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    Int?
  product      String
  qty          Int        @default(1)
  rate         Decimal    @default(0.00) @db.Decimal(10, 2)
  total        Decimal    @default(0.00) @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@schema("crackers")
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  mobile    String?
  role      String?
  salary      Decimal  @default(0.00) @db.Decimal(10, 2)
  paymentType String   @default("Monthly")
  unit        String?
  status      String   @default("Active")
  advanceBalance Decimal @default(0.00) @db.Decimal(12, 2)
  payrolls  Payroll[]
  dailyProductions DailyProduction[]
  advances  EmployeeAdvance[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("crackers")

}

model EmployeeAdvance {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id])
  date        DateTime
  type        String   // "GIVEN" or "RECOVERED"
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@schema("crackers")

}

model Payroll {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id])
  month         String
  paymentType   String   @default("Monthly")
  daysWorked    Int      @default(0)
  basicSalary   Decimal  @default(0.00) @db.Decimal(10, 2)
  allowance   Decimal  @default(0.00) @db.Decimal(10, 2)
  deduction   Decimal  @default(0.00) @db.Decimal(10, 2)
  netSalary   Decimal  @default(0.00) @db.Decimal(12, 2)
  status      String   @default("Paid") // Paid, Pending
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@schema("crackers")

}

model DailyProduction {
  id          Int      @id @default(autoincrement())
  date        DateTime
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id])
  totalAmount Decimal  @default(0.00) @db.Decimal(12, 2)
  items       DailyProductionItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@schema("crackers")

}

model DailyProductionItem {
  id                Int             @id @default(autoincrement())
  dailyProductionId Int
  dailyProduction   DailyProduction @relation(fields: [dailyProductionId], references: [id], onDelete: Cascade)
  itemName          String
  quantity          Int             @default(0)
  pieceRate         Decimal         @default(0.00) @db.Decimal(10, 2)
  total             Decimal         @default(0.00) @db.Decimal(12, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  @@schema("crackers")

}

model CompanyProfile {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  gstin     String   @unique
  address   String?
  city      String?
  district  String?
  state     String
  pincode   String?
  addresses Json?    @default("[]")
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invoices  Invoice[]
  billingSeries BillingSeries[]
  @@schema("crackers")

}

model BillingSeries {
  id               Int            @id @default(autoincrement())
  companyProfileId Int
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  prefix           String
  name             String
  lastNumber       Int            @default(0)
  status           String         @default("Active")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([companyProfileId, prefix])
  @@schema("crackers")

}

